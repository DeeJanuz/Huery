{
  "name": "heury",
  "version": "0.1.0",
  "description": "Local-first codebase analysis tool for LLM discovery",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "heury": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup && npm run build:ui && cp -r src/adapters/storage/migrations dist/cli/",
    "build:ui": "cd src/adapters/ui/client && npx vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/djgrant/heury.git"
  },
  "homepage": "https://github.com/djgrant/heury",
  "author": "Deej <deej@ludflow.com>",
  "keywords": [
    "codebase-analysis",
    "mcp",
    "llm",
    "code-intelligence",
    "static-analysis"
  ],
  "license": "Elastic-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3"
  }
}
